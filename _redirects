function encodeInput(input) {
  return btoa(unescape(encodeURIComponent(JSON.stringify(input))))
    .replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
}
function decodeInput(payload) {
  const normalized = payload.replace(/-/g, '+').replace(/_/g, '/');
  const padded = normalized + '='.repeat((4 - normalized.length % 4) % 4);
  return JSON.parse(decodeURIComponent(escape(atob(padded))));
}
function sanitizeBaseUrl(value) {
  const raw = String(value || '').trim();
  if (!raw) return '';
  try {
    const url = new URL(raw);
    if (!/^https?:$/.test(url.protocol)) return '';
    url.search = '';
    url.hash = '';
    return url.toString();
  } catch {
    return '';
  }
}
function getStoredShareBase() {
  try { return sanitizeBaseUrl(localStorage.getItem('pairAuraShareBaseUrl') || ''); }
  catch { return ''; }
}
function setStoredShareBase(value) {
  const cleaned = sanitizeBaseUrl(value);
  try {
    if (cleaned) localStorage.setItem('pairAuraShareBaseUrl', cleaned);
    else localStorage.removeItem('pairAuraShareBaseUrl');
  } catch {}
  state.shareBaseUrl = cleaned;
  return cleaned;
}
function getCurrentPageBase() {
  try {
    const url = new URL(window.location.href);
    url.search = '';
    url.hash = '';
    return url;
  } catch {
    return null;
  }
}
function buildLocalReportUrl(input) {
  const url = getCurrentPageBase();
  if (!url) return window.location.href;
  url.searchParams.set('r', encodeInput(input));
  return url.toString();
}
function buildReportUrl(input) {
  const payload = encodeInput(input);
  const base = state.shareBaseUrl || getStoredShareBase();
  let url;
  if (base) {
    url = new URL(base);
  } else {
    url = getCurrentPageBase() || new URL('https://example.com/');
  }
  url.searchParams.set('r', payload);
  return url.toString();
}
function canReplaceWith(urlString) {
  try {
    const next = new URL(urlString, window.location.href);
    return next.origin === window.location.origin || window.location.protocol === 'file:';
  } catch { return false; }
}
function safeReplaceState(urlString) {
  try {
    if (canReplaceWith(urlString)) history.replaceState(null, '', urlString);
  } catch {}
}
function isLikelyPublicUrl(urlString) {
  try {
    const url = new URL(urlString);
    return /^https?:$/.test(url.protocol) && !['localhost', '127.0.0.1', '0.0.0.0'].includes(url.hostname);
  } catch { return false; }
}
function isLocalPreviewUrl(urlString) {
  try {
    const url = new URL(urlString);
    return url.protocol === 'file:' || ['localhost', '127.0.0.1', '0.0.0.0'].includes(url.hostname);
  } catch { return true; }
}
function shareMessage(report, url) {
