function strongestGap(gaps) {
  const map = [
    ['socialGap', '社交能量'], ['emotionalGap', '情绪表达'], ['intimacyGap', '亲密需求'], ['independenceGap', '独立空间'],
    ['conflictGap', '冲突处理'], ['planningGap', '行动计划'], ['stabilityGap', '稳定需求'], ['logicGap', '理性/感性决策'], ['noveltyGap', '新鲜感需求']
  ];
  const sorted = map.sort((a, b) => (gaps[b[0]] || 0) - (gaps[a[0]] || 0));
  return { key: sorted[0][0], label: sorted[0][1], value: gaps[sorted[0][0]] || 0 };
}

function topGaps(gaps, count = 3) {
  const labels = {
    socialGap: '社交能量', emotionalGap: '情绪表达', intimacyGap: '亲密需求', independenceGap: '独立空间',
    conflictGap: '冲突处理', planningGap: '行动计划', stabilityGap: '稳定需求', logicGap: '理性/感性决策', noveltyGap: '新鲜感需求'
  };
  return Object.entries(labels)
    .map(([key, label]) => ({ key, label, value: gaps[key] || 0 }))
    .sort((a, b) => b.value - a.value)
    .slice(0, count);
}

