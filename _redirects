function compareFacetHighlights(profileA, profileB) {
  if (!profileA.aspects || !profileB.aspects) return [];
  const mapB = new Map(profileB.aspects.facets.map(f => [`${f.pair}-${f.leftEnglish}`, f]));
  return profileA.aspects.facets.map(fa => {
    const fb = mapB.get(`${fa.pair}-${fa.leftEnglish}`);
    const diff = fb ? Math.abs(fa.score - fb.score) : 0;
    return { pair: fa.pair, name: `${fa.leftLabel} ↔ ${fa.rightLabel}`, a: fa.label, b: fb ? fb.label : '', diff };
  }).sort((x, y) => y.diff - x.diff).slice(0, 6);
}

