  refreshShareUrl();
  const link = state.currentReportUrl || window.location.href;
  return copyText(link, isLikelyPublicUrl(link) ? '公开报告链接已复制' : '链接已复制。本地预览链接发给别人可能打不开');
}
async function copyShareText() {
  refreshShareUrl();
  const text = shareMessage(state.currentReport, state.currentReportUrl || window.location.href);
  return copyText(text, '分享文案已复制');
}
async function nativeShare() {
  const report = state.currentReport;
  if (!report) return;
  refreshShareUrl();
  const url = state.currentReportUrl;
  const text = report.shareText;
  if (navigator.share) {
    try {
      await navigator.share({ title: 'Pair Aura 关系气场报告', text, url });
      return;
    } catch (err) {
      if (err.name === 'AbortError') return;
    }
  }
  copyShareText();
}
function applyPublicBaseUrl() {
  const input = $('#publicBaseUrlInput');
  const raw = input ? input.value : '';
  const cleaned = setStoredShareBase(raw);
  if (input) input.value = cleaned;
  if (!cleaned && raw.trim()) {
    toast('请输入以 https:// 或 http:// 开头的公开首页地址');
    return;
  }
  refreshShareUrl();
  if (state.currentReport) drawPoster(state.currentReport, state.currentReportUrl);
  toast(cleaned ? '公开域名已应用，二维码和链接已更新' : '已清除公开域名，恢复当前页面链接');
}
function openShareUrl() {
  refreshShareUrl();
  if (!state.currentReportUrl) return;
  window.open(state.currentReportUrl, '_blank', 'noopener,noreferrer');
}

function loadFromUrl() {
  const payload = new URLSearchParams(window.location.search).get('r');
  if (!payload) return false;
  try {
    const input = decodeInput(payload);
    const normalized = normalizeInput(input);
    state.selectedContext = normalized.context;
    state.selectedStyle = normalized.style;
    state.currentInput = normalized;
    state.currentReport = createReport(normalized);
    state.currentReportUrl = buildReportUrl(normalized);
    renderReport(state.currentReport);
    showView('reportView');
    return true;
  } catch (err) {
    console.warn('Invalid report payload', err);
    return false;
  }
}

function hydrateForm(input) {
  if (!input) return;
  input = normalizeInput(input);
  state.selectedContext = input.context || state.selectedContext;
  state.selectedStyle = input.style || state.selectedStyle;
  renderChoices();
  $('#nameA').value = input.personA.name || '我';
  $('#nameB').value = input.personB.name || 'TA';
  $('#systemA').value = input.personA.system || 'mbti';
  updateTypeSelect('A');
  $('#typeA').value = input.personA.type || 'ENFP';
  if ($('#variantA')) $('#variantA').value = input.personA.variant || 'standard';
  $('#systemB').value = input.personB.system || 'mbti';
  updateTypeSelect('B');
  $('#typeB').value = input.personB.type || 'ISTJ';
  if ($('#variantB')) $('#variantB').value = input.personB.variant || 'standard';
}

function initEvents() {
  $('#startBtn').addEventListener('click', () => showView('inputView'));
  $('#jumpToInputBtn').addEventListener('click', () => showView('inputView'));
  $('#loadDemoBtn').addEventListener('click', () => generate({ context: 'close', style: 'warm_roast', personA: { name: '我', system: 'mbti', type: 'ENFP', variant: 'expressive' }, personB: { name: 'TA', system: 'mbti', type: 'ISTJ', variant: 'planful' } }));
  $all('[data-back-home]').forEach(btn => btn.addEventListener('click', () => showView('homeView')));
  $all('[data-edit]').forEach(btn => btn.addEventListener('click', () => { hydrateForm(state.currentInput); showView('inputView'); }));
  $all('[data-share-link]').forEach(btn => btn.addEventListener('click', nativeShare));
  $all('[data-back-report]').forEach(btn => btn.addEventListener('click', () => showView('reportView')));
  $('#downloadPosterBtn').addEventListener('click', downloadPoster);
  $('#copyLinkBtn').addEventListener('click', copyCurrentLink);
  $('#copyShareTextBtn').addEventListener('click', copyShareText);
  $('#copyShareTextBtn2').addEventListener('click', copyShareText);
  $('#nativeShareBtn').addEventListener('click', nativeShare);
  $('#applyBaseUrlBtn').addEventListener('click', applyPublicBaseUrl);
  $('#openShareUrlBtn').addEventListener('click', openShareUrl);

  $('#contextChoices').addEventListener('click', (event) => {
    const btn = event.target.closest('[data-context]');
    if (!btn) return;
    state.selectedContext = btn.dataset.context;
    renderChoices();
  });
  $('#styleChoices').addEventListener('click', (event) => {
    const btn = event.target.closest('[data-style]');
    if (!btn) return;
    state.selectedStyle = btn.dataset.style;
    renderChoices();
  });
  $('#reportForm').addEventListener('submit', (event) => {
    event.preventDefault();
    generate(currentInputFromForm());
  });
}

function main() {
  state.shareBaseUrl = getStoredShareBase();
  renderChoices();
  initSelects();
  initEvents();
  if (!loadFromUrl()) showView('homeView');
}

document.addEventListener('DOMContentLoaded', main);

  </script>
</body>
</html>
