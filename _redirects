function scoreDimensions(vecA, vecB) {
  const emotionalGap = gap(vecA, vecB, 'emotional_expression');
  const intimacyGap = gap(vecA, vecB, 'intimacy_need');
  const independenceGap = gap(vecA, vecB, 'independence_need');
  const conflictGap = gap(vecA, vecB, 'conflict_directness');
  const planningGap = gap(vecA, vecB, 'planning');
  const socialGap = gap(vecA, vecB, 'social_energy');
  const stabilityGap = gap(vecA, vecB, 'stability_need');
  const logicGap = gap(vecA, vecB, 'logic_orientation');
  const noveltyGap = gap(vecA, vecB, 'novelty');
  const cooperationAvg = avg([vecA.cooperation, vecB.cooperation]);

  const similarity = clamp(100 - avg([socialGap, emotionalGap, planningGap, noveltyGap, intimacyGap, stabilityGap]) * 0.86, 0, 100);
  const complementarity = clamp(avg([
    idealGapScore(socialGap, 28),
    idealGapScore(logicGap, 34),
    idealGapScore(planningGap, 30),
    idealGapScore(noveltyGap, 24),
    idealGapScore(emotionalGap, 28)
  ]), 0, 100);
  const conflictRisk = clamp(0.20 * emotionalGap + 0.18 * intimacyGap + 0.14 * independenceGap + 0.19 * conflictGap + 0.18 * planningGap + 0.11 * stabilityGap, 0, 100);

  const dimensions = {
    emotional_sync: clamp(100 - 0.52 * emotionalGap - 0.24 * intimacyGap + 0.10 * cooperationAvg, 0, 100),
    communication: clamp(100 - 0.42 * conflictGap - 0.18 * logicGap + 0.18 * cooperationAvg, 0, 100),
    lifestyle: clamp(100 - 0.46 * planningGap - 0.26 * stabilityGap - 0.18 * socialGap, 0, 100),
    goal_fit: clamp(100 - 0.34 * planningGap - 0.22 * noveltyGap - 0.10 * logicGap + 0.18 * cooperationAvg, 0, 100),
    complementarity,
    conflict_repair: clamp(100 - 0.68 * conflictRisk + 0.18 * cooperationAvg, 0, 100)
  };
  dimensions.long_term_comfort = clamp(0.20 * dimensions.emotional_sync + 0.18 * dimensions.communication + 0.22 * dimensions.lifestyle + 0.16 * dimensions.conflict_repair + 0.14 * dimensions.goal_fit + 0.10 * dimensions.complementarity, 0, 100);

  return {
    dimensions: roundObject(dimensions),
    similarity: Math.round(similarity),
    complementarity: Math.round(complementarity),
    conflictRisk: Math.round(conflictRisk),
    gaps: {
      socialGap: Math.round(socialGap), emotionalGap: Math.round(emotionalGap), intimacyGap: Math.round(intimacyGap),
      independenceGap: Math.round(independenceGap), conflictGap: Math.round(conflictGap), planningGap: Math.round(planningGap),
      stabilityGap: Math.round(stabilityGap), logicGap: Math.round(logicGap), noveltyGap: Math.round(noveltyGap)
    }
  };
}

