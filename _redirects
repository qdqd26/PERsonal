    scoreBreakdown: { similarity: stats.similarity, complementarity: stats.complementarity, friction: stats.conflictRisk },
    algorithmHighlights: topGaps(stats.gaps, 3),
    punchline: punchlineForReport(relationship, stats, input.style),
    sceneCards: sceneExpansionCards(input.context, input.style, stats),
    facetComparison: compareFacetHighlights(profileA, profileB),
