<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#120B2E" />
  <meta name="description" content="输入两个人的 MBTI / SBTI 类型，生成短、准、好分享的关系气场报告。" />
  <meta name="application-name" content="Pair Aura" />
  <meta name="apple-mobile-web-app-title" content="Pair Aura" />
  <meta name="format-detection" content="telephone=no" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Pair Aura 关系气场报告" />
