function buildStep2Facets(type, vector) {
  const letterValues = {
    'E/I': type[0] === 'E' ? vector.social_energy : 100 - vector.social_energy,
    'S/N': type[1] === 'S' ? vector.detail_focus : vector.novelty,
    'T/F': type[2] === 'T' ? vector.logic_orientation : 100 - vector.logic_orientation,
    'J/P': type[3] === 'J' ? vector.planning : 100 - vector.planning
  };
  const nuance = {
    'E/I': [vector.decision_speed, vector.emotional_expression, vector.social_energy, vector.change_readiness, vector.emotional_expression],
    'S/N': [vector.detail_focus, 100 - vector.change_readiness, vector.detail_focus, 100 - vector.novelty + 40, vector.stability_need],
    'T/F': [vector.logic_orientation, 100 - vector.emotional_expression + 30, vector.conflict_directness, vector.conflict_directness, vector.logic_orientation],
    'J/P': [vector.planning, vector.planning, vector.decision_speed, vector.planning, vector.detail_focus]
  };
  const facets = [];
  MBTI_STEP2_GROUPS.forEach(group => {
    group.facets.forEach((f, i) => {
      const leftPreferred = type.includes(group.pair[0]);
      const seed = clamp(avg([letterValues[group.pair], nuance[group.pair][i]]), 0, 100);
      const leftScore = leftPreferred ? seed : 100 - seed;
      const side = leftScore >= 50 ? 'left' : 'right';
      facets.push({
        pair: group.pair,
        leftEnglish: f[0], leftLabel: f[1], rightEnglish: f[2], rightLabel: f[3],
        label: side === 'left' ? f[1] : f[3],
        english: side === 'left' ? f[0] : f[2],
        opposite: side === 'left' ? f[3] : f[1],
        score: Math.round(leftScore),
        strength: Math.round(clamp(Math.max(leftScore, 100 - leftScore), 45, 95))
      });
    });
  });
  return facets;
}

function mbtiAspectProfile(type, vector) {
  if (!MBTI_TYPES.includes(type)) return null;
  const axes = [
