  g.addColorStop(0, color);
  g.addColorStop(1, 'rgba(255,255,255,0)');
  ctx.fillStyle = g;
  ctx.beginPath();
  ctx.arc(x, y, r, 0, Math.PI * 2);
  ctx.fill();
}
function drawPosterStars(ctx, w, h) {
  ctx.fillStyle = 'rgba(255,255,255,.22)';
  for (let i = 0; i < 90; i++) {
    const x = (i * 97) % w;
    const y = (i * 193) % h;
    ctx.beginPath();
    ctx.arc(x, y, i % 3 === 0 ? 2 : 1, 0, Math.PI * 2);
    ctx.fill();
  }
}
