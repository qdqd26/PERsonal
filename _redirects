  <title>Pair Aura 关系气场报告</title>
  <style>
:root {
  --bg: #120b2e;
  --card: rgba(255, 255, 255, 0.12);
  --card-strong: rgba(255, 255, 255, 0.18);
  --stroke: rgba(255, 255, 255, 0.20);
  --text: #ffffff;
  --muted: #cfc7ff;
  --muted-2: #9f94d6;
  --pink: #ff5ca8;
  --purple: #7b61ff;
  --blue: #46d9ff;
  --green: #78f2c2;
  --yellow: #ffe66d;
  --shadow: 0 22px 80px rgba(0, 0, 0, 0.35);
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

* { box-sizing: border-box; }
html { min-height: 100%; background: var(--bg); }
body {
  min-height: 100vh;
  margin: 0;
  color: var(--text);
  background:
    radial-gradient(circle at 20% 10%, rgba(255, 92, 168, 0.32), transparent 30%),
    radial-gradient(circle at 78% 24%, rgba(70, 217, 255, 0.26), transparent 32%),
    linear-gradient(160deg, #120b2e 0%, #1b0f42 45%, #090719 100%);
  overflow-x: hidden;
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background-image: radial-gradient(rgba(255,255,255,.14) 1px, transparent 1px);
  background-size: 34px 34px;
  mask-image: linear-gradient(to bottom, rgba(0,0,0,.45), transparent 75%);
}

.ambient {
  position: fixed;
  width: 360px;
  height: 360px;
  border-radius: 999px;
  filter: blur(70px);
  opacity: .55;
  pointer-events: none;
  z-index: 0;
}
.ambient-a { background: var(--pink); left: -160px; top: 8vh; }
.ambient-b { background: var(--blue); right: -150px; top: 24vh; }
.ambient-c { background: var(--purple); left: 26vw; bottom: -190px; }

.app-shell {
  position: relative;
  z-index: 1;
  width: min(980px, 100%);
  margin: 0 auto;
  padding: max(16px, env(safe-area-inset-top)) 16px 30px;
}

.view { display: none; animation: fadeIn .28s ease; }
.view.active { display: block; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  min-height: 48px;
  margin-bottom: 12px;
}
.sticky-nav {
  position: sticky;
  top: 0;
  z-index: 5;
  padding: 8px 0;
  backdrop-filter: blur(20px);
}
.brand-mark {
  font-weight: 800;
  letter-spacing: .06em;
  text-transform: uppercase;
  font-size: 14px;
  color: rgba(255,255,255,.92);
}

button, input, select { font: inherit; }
button { cursor: pointer; border: 0; }
.primary-btn, .secondary-btn, .ghost-btn {
  border-radius: 999px;
  padding: 14px 20px;
  transition: transform .18s ease, opacity .18s ease, box-shadow .18s ease;
}
.primary-btn {
  color: #160b32;
  font-weight: 800;
  background: linear-gradient(135deg, var(--yellow), var(--green) 35%, var(--blue) 70%, var(--pink));
  box-shadow: 0 16px 44px rgba(70, 217, 255, .25);
}
.secondary-btn {
  color: var(--text);
  background: rgba(255,255,255,.12);
  border: 1px solid var(--stroke);
}
.ghost-btn {
  color: var(--text);
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.12);
}
.small { padding: 9px 13px; font-size: 13px; }
.wide { width: 100%; margin-top: 22px; }
button:hover { transform: translateY(-1px); }
button:active { transform: translateY(1px) scale(.99); }

.home-view {
  min-height: calc(100vh - 50px);
  display: none;
  align-content: start;
}
.home-view.active { display: grid; }
.hero-orbit {
  position: relative;
  height: 260px;
  margin-top: 12px;
}
.aura {
  position: absolute;
  top: 48px;
  width: 170px;
  height: 170px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  font-weight: 900;
  font-size: 44px;
  color: white;
  box-shadow: inset 0 0 34px rgba(255,255,255,.28), 0 0 70px rgba(255,255,255,.18);
  animation: float 4s ease-in-out infinite;
}
.aura-left {
  left: calc(50% - 175px);
  background: radial-gradient(circle at 35% 35%, #fff, #ff8bc4 18%, #7b61ff 58%, rgba(123,97,255,.16));
}
.aura-right {
  right: calc(50% - 175px);
  animation-delay: -1.5s;
  background: radial-gradient(circle at 35% 35%, #fff, #80f2ff 18%, #46d9ff 46%, rgba(255,92,168,.28));
}
.aura-core {
  position: absolute;
  inset: 88px 0 auto;
  margin: auto;
  width: 105px;
  height: 105px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,.9), rgba(255,230,109,.62), transparent 66%);
  filter: blur(1px);
  opacity: .72;
}
@keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-14px); } }

.hero-copy { text-align: center; }
.eyebrow {
  margin: 0 0 10px;
  color: var(--green);
  font-size: 12px;
  font-weight: 800;
  letter-spacing: .16em;
}
h1 {
  margin: 0;
  font-size: clamp(42px, 9vw, 82px);
  line-height: 1.02;
  letter-spacing: -.05em;
}
.subtitle {
  width: min(560px, 100%);
  margin: 18px auto 0;
  color: var(--muted);
  font-size: 16px;
  line-height: 1.7;
}
.hero-actions {
  display: flex;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
  margin: 26px 0 16px;
}
.sample-tags {
  display: flex;
  gap: 10px;
  justify-content: center;
  flex-wrap: wrap;
  color: rgba(255,255,255,.86);
}
.sample-tags span {
  padding: 9px 12px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.16);
  background: rgba(255,255,255,.08);
}

.form-card, .report-card, .poster-panel {
  background: linear-gradient(180deg, rgba(255,255,255,.16), rgba(255,255,255,.08));
  border: 1px solid var(--stroke);
  border-radius: 30px;
  box-shadow: var(--shadow);
  backdrop-filter: blur(24px);
}
.form-card { padding: 20px; }
.section-title {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  margin-bottom: 14px;
}
.section-title > span {
  flex: 0 0 auto;
  display: grid;
  place-items: center;
  width: 36px;
  height: 36px;
  border-radius: 12px;
  background: rgba(255,255,255,.15);
  color: var(--yellow);
  font-weight: 900;
}
.section-title h2 { margin: 0; font-size: 22px; }
.section-title p { margin: 5px 0 0; color: var(--muted); line-height: 1.5; }
.gap-top { margin-top: 28px; }
.choice-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}
.choice-grid.compact { grid-template-columns: repeat(2, 1fr); }
.choice-card {
  min-height: 118px;
  padding: 16px;
  border-radius: 22px;
  border: 1px solid rgba(255,255,255,.14);
  background: rgba(255,255,255,.08);
  color: var(--text);
  text-align: left;
}
.choice-card strong { display: block; margin: 8px 0 5px; }
.choice-card p { margin: 0; color: var(--muted); font-size: 13px; line-height: 1.45; }
.choice-card.active {
  background: linear-gradient(135deg, rgba(255,92,168,.24), rgba(70,217,255,.18));
  border-color: rgba(255,255,255,.42);
  box-shadow: 0 14px 32px rgba(70,217,255,.16);
}
.people-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14px;
}
.person-card {
  padding: 16px;
  border-radius: 24px;
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.14);
}
.person-head {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 12px;
}
.person-badge {
  width: 38px;
  height: 38px;
  display: grid;
  place-items: center;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--pink), var(--purple));
  font-weight: 900;
}
.person-badge.alt { background: linear-gradient(135deg, var(--blue), var(--green)); }
label {
  display: block;
  margin: 12px 0 7px;
  color: var(--muted);
  font-size: 13px;
}
input, select {
  width: 100%;
  color: white;
  background: rgba(18, 11, 46, .52);
  border: 1px solid rgba(255,255,255,.18);
  border-radius: 15px;
  padding: 12px 13px;
  outline: none;
}
select option { color: #111; }
.fine-print { color: var(--muted-2); font-size: 12px; line-height: 1.6; text-align: center; }

.loading-view.active {
  min-height: 70vh;
  display: grid;
  place-items: center;
  text-align: center;
}
.loader-orbit {
  position: relative;
  width: 170px;
  height: 170px;
  margin: 0 auto 24px;
}
.loader-orbit div {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2px solid transparent;
  border-top-color: var(--pink);
  animation: spin 1.8s linear infinite;
}
.loader-orbit div:nth-child(2) { inset: 18px; border-top-color: var(--blue); animation-duration: 1.4s; animation-direction: reverse; }
.loader-orbit div:nth-child(3) { inset: 38px; border-top-color: var(--green); animation-duration: 1.1s; }
@keyframes spin { to { transform: rotate(360deg); } }

.report-hero {
  padding: 26px;
  border-radius: 34px;
  background:
    radial-gradient(circle at 26% 16%, rgba(255,92,168,.35), transparent 35%),
    radial-gradient(circle at 78% 36%, rgba(70,217,255,.28), transparent 35%),
    linear-gradient(160deg, rgba(255,255,255,.18), rgba(255,255,255,.08));
  border: 1px solid var(--stroke);
  box-shadow: var(--shadow);
}
.report-hero h2 { margin: 6px 0 8px; font-size: clamp(38px, 8vw, 70px); line-height: 1; letter-spacing: -.05em; }
.report-hero .score { font-size: 76px; line-height: 1; font-weight: 900; margin: 16px 0 8px; }
.report-hero .score span { font-size: 28px; color: var(--muted); }
.keyword-row { display: flex; flex-wrap: wrap; gap: 8px; margin: 14px 0; }
.keyword-row span {
  padding: 8px 12px;
  border-radius: 999px;
  background: rgba(255,255,255,.14);
  color: var(--yellow);
  font-weight: 700;
}
.summary { color: var(--muted); line-height: 1.7; font-size: 16px; }
.quick-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 20px; }

.comparison-grid, .content-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14px;
  margin-top: 14px;
}
.report-card { padding: 18px; }
.report-card h3 { margin: 0 0 8px; font-size: 18px; }
.report-card p { margin: 0; color: var(--muted); line-height: 1.65; }
.type-pill { display: inline-flex; gap: 8px; align-items: center; padding: 8px 12px; border-radius: 999px; background: rgba(255,255,255,.10); margin-bottom: 10px; }
.dim-card { margin-top: 14px; }
.dim-item { margin: 15px 0; }
.dim-head { display: flex; justify-content: space-between; color: rgba(255,255,255,.9); font-weight: 700; margin-bottom: 8px; }
.dim-track { height: 12px; border-radius: 999px; background: rgba(255,255,255,.12); overflow: hidden; }
.dim-fill { height: 100%; border-radius: inherit; background: linear-gradient(90deg, var(--pink), var(--blue), var(--green)); }
.stat-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-top: 14px;
}
.stat-strip div {
  padding: 16px;
  border-radius: 22px;
  background: rgba(255,255,255,.09);
  border: 1px solid rgba(255,255,255,.12);
  text-align: center;
}
.stat-strip strong { display: block; font-size: 28px; }
.stat-strip span { color: var(--muted); font-size: 12px; }


.resource-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin: 12px 0 4px;
}
.link-card {
  display: block;
  padding: 15px;
  border-radius: 22px;
  background: rgba(255,255,255,.09);
  border: 1px solid rgba(255,255,255,.14);
  color: var(--text);
  text-decoration: none;
  transition: transform .18s ease, background .18s ease, border-color .18s ease;
}
.link-card:hover { transform: translateY(-2px); background: rgba(255,255,255,.14); border-color: rgba(255,255,255,.28); }
.link-card strong { display: block; font-size: 15px; margin-bottom: 5px; }
.link-card span { display: block; color: var(--muted); font-size: 13px; line-height: 1.45; }
.metric-panel { margin-top: 14px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,.12); }
.metric-panel h4, .facet-section h4 { margin: 0 0 10px; font-size: 14px; color: rgba(255,255,255,.92); }
.mini-metric { margin: 10px 0; }
.mini-metric-head { display: flex; justify-content: space-between; gap: 8px; font-size: 12px; color: rgba(255,255,255,.86); margin-bottom: 5px; }
.mini-track { height: 8px; border-radius: 999px; overflow: hidden; background: rgba(255,255,255,.12); }
.mini-fill { height: 100%; border-radius: inherit; background: linear-gradient(90deg, var(--pink), var(--blue), var(--green)); }
.facet-section { margin-top: 16px; }
.facet-chips { display: flex; flex-wrap: wrap; gap: 8px; }
.facet-chip {
  padding: 8px 10px;
  border-radius: 999px;
  background: rgba(255,255,255,.10);
  border: 1px solid rgba(255,255,255,.12);
  color: rgba(255,255,255,.88);
  font-size: 12px;
  line-height: 1.1;
}
.facet-chip.hot { background: rgba(255,230,109,.12); border-color: rgba(255,230,109,.34); color: #fff6b0; }
.facet-compare-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; margin-top: 10px; }
.facet-compare-card { padding: 12px; border-radius: 18px; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.12); }
.facet-compare-card strong { display: block; margin-bottom: 4px; font-size: 13px; }
.facet-compare-card span { color: var(--muted); font-size: 12px; line-height: 1.45; }
.roast-card { border-color: rgba(255,230,109,.35); background: linear-gradient(180deg, rgba(255,230,109,.16), rgba(255,92,168,.10)); }
.source-note { margin-top: 10px; color: rgba(255,255,255,.54); font-size: 12px; line-height: 1.55; }

.poster-panel { padding: 16px; }
#posterCanvas {
  display: block;
  width: min(100%, 430px);
  height: auto;
  margin: 0 auto;
  border-radius: 28px;
  box-shadow: var(--shadow);
  background: #120b2e;
}
.poster-actions { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-top: 18px; }

.share-tools {
  width: min(100%, 720px);
  margin: 18px auto 0;
  padding: 16px;
  border-radius: 24px;
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.14);
  box-shadow: 0 18px 48px rgba(0,0,0,.18);
}
.share-tools h3 { margin: 0 0 8px; font-size: 17px; }
.share-tools p { margin: 0 0 12px; color: var(--muted); font-size: 13px; line-height: 1.55; }
.share-row { display: grid; grid-template-columns: 1fr auto; gap: 10px; align-items: center; margin: 10px 0; }
.share-row input, .share-row textarea {
  width: 100%;
  border: 1px solid rgba(255,255,255,.16);
  background: rgba(5,3,18,.42);
  color: #fff;
  border-radius: 16px;
  padding: 12px 14px;
  outline: none;
  font-size: 13px;
  line-height: 1.5;
  min-width: 0;
}
.share-row textarea { min-height: 78px; resize: vertical; }
.share-row input:focus, .share-row textarea:focus { border-color: rgba(120,242,194,.48); box-shadow: 0 0 0 3px rgba(120,242,194,.12); }
.share-status { margin-top: 8px; color: #fff6b0; font-size: 12px; line-height: 1.55; }
.share-status.ok { color: #baffdf; }
.share-status.warn { color: #fff6b0; }
.qr-status { text-align: center; margin-top: 10px; color: rgba(255,255,255,.62); font-size: 12px; }
.toast {
  position: fixed;
  left: 50%;
  bottom: 28px;
  transform: translateX(-50%) translateY(20px);
  opacity: 0;
  z-index: 20;
  max-width: min(480px, calc(100% - 28px));
  padding: 12px 16px;
  border-radius: 999px;
  background: rgba(0,0,0,.72);
  color: white;
  pointer-events: none;
  transition: .22s ease;
  text-align: center;
}
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

@media (max-width: 760px) {
  .choice-grid, .choice-grid.compact, .people-grid, .comparison-grid, .content-grid, .resource-grid, .facet-compare-grid, .share-row { grid-template-columns: 1fr; }
  .form-card { padding: 16px; border-radius: 24px; }
  .aura { width: 142px; height: 142px; }
  .aura-left { left: calc(50% - 145px); }
  .aura-right { right: calc(50% - 145px); }
  .hero-orbit { height: 232px; }
  .hero-actions .primary-btn, .hero-actions .secondary-btn { width: 100%; }
  .stat-strip { grid-template-columns: 1fr; }
  .top-nav { margin-bottom: 8px; }
}

  
.official-only { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.variant-select { margin-bottom: 6px; }
.compact-note { color: var(--muted); font-size: 13px; line-height: 1.65; }
.compact-chips { margin-top: 10px; }
.hero-stats { margin: 20px 0 0; }
.highlight-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 16px; }
.highlight-chip { padding: 12px; border-radius: 18px; background: rgba(255,255,255,.10); border: 1px solid rgba(255,255,255,.16); }
.highlight-chip strong { display: block; color: #fff; font-size: 15px; }
.highlight-chip span { display: block; color: var(--muted); font-size: 12px; margin-top: 4px; }
.compact-content { grid-template-columns: repeat(3, 1fr); }
.compact-algo-card { margin-top: 14px; }
.compact-facet-grid { grid-template-columns: repeat(3, 1fr); }
@media (max-width: 760px) { .official-only, .highlight-row, .compact-content, .compact-facet-grid { grid-template-columns: 1fr; } }

.scene-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; margin-top: 14px; }
.scene-card { position: relative; overflow: hidden; }
.scene-card::after { content: ""; position: absolute; width: 120px; height: 120px; right: -42px; top: -48px; border-radius: 50%; background: radial-gradient(circle, rgba(255,230,109,.22), transparent 70%); }
.algo-focus { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 14px; }
.algo-focus .focus-item { padding: 15px; border-radius: 22px; background: rgba(255,255,255,.09); border: 1px solid rgba(255,255,255,.13); text-align: center; }
.algo-focus strong { display: block; font-size: 30px; line-height: 1; }
.algo-focus span { display: block; color: var(--muted); font-size: 12px; margin-top: 6px; }
.punchline { color: #fff; font-size: 18px; line-height: 1.7; margin: 18px 0 0; }
@media (max-width: 760px) { .scene-grid, .algo-focus { grid-template-columns: 1fr; } }

</style>
